{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Watchdog Auto Start",
      "type": "shell",
      "command": "nohup bash ./scripts/watchdog.sh >> ./watchdog.log 2>&1 &",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
